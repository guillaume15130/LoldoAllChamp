<Window x:Class="LoldoAllChamp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LoldoAllChamp - Défi Champions LoL"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#16213e" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="LoldoAllChamp"
                           FontSize="28" FontWeight="Bold" Foreground="#e94560"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock Text="Joueur : " Foreground="#a8a8b3" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PlayerNameText" Foreground="#e94560" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="3" x:Name="ChangePlayerButton" Content="Changer de joueur"
                        Style="{StaticResource SecondaryButtonStyle}" Click="ChangePlayerButton_Click"/>
            </Grid>
        </Border>

        <!-- Stats bar -->
        <Border Grid.Row="1" Background="#0f3460" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="StatsText" Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                    <ProgressBar x:Name="ProgressBar" Width="300" Height="20" Margin="15,0,0,0"
                                 Foreground="#e94560" Background="#1a1a2e" VerticalAlignment="Center"/>
                    <Button x:Name="UndoButton" Content="↩ Annuler le dernier"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="15,0,0,0"
                            Click="UndoButton_Click" Visibility="Collapsed"/></StackPanel>

                <CheckBox Grid.Column="2" x:Name="ShowCompletedCheckBox" Content="Afficher les champions terminés"
                          Foreground="White" FontSize="14" VerticalAlignment="Center" Margin="0,0,15,0"
                          IsChecked="False" Checked="ShowCompletedCheckBox_Changed" Unchecked="ShowCompletedCheckBox_Changed"/>

                <TextBox Grid.Column="3" x:Name="SearchBox" Width="200" Height="30"
                         Style="{StaticResource SearchBoxStyle}"
                         TextChanged="SearchBox_TextChanged"/>
            </Grid>
        </Border>

        <!-- Champions Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="10">
            <ItemsControl x:Name="ChampionsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource ChampionButtonStyle}"
                                Click="ChampionButton_Click"
                                Tag="{Binding Id}"
                                ToolTip="{Binding Name}">
                            <Grid Width="90" Height="110">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="80"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" CornerRadius="8" ClipToBounds="True"
                                        BorderBrush="#e94560" BorderThickness="2">
                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <TextBlock Grid.Row="1" Text="{Binding Name}"
                                           Foreground="White" FontSize="10"
                                           TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" Margin="0,2,0,0"/>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
