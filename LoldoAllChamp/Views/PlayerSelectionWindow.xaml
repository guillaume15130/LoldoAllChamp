<Window x:Class="LoldoAllChamp.Views.PlayerSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LoldoAllChamp - Choix du joueur"
        Width="500" Height="400"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e"
        ResizeMode="NoResize">

    <Grid>
        <Border Background="#16213e" CornerRadius="15" Margin="30" Padding="30">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="LoldoAllChamp"
                           FontSize="36" FontWeight="Bold" Foreground="#e94560"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="Défi : Jouer tous les champions !"
                           FontSize="14" Foreground="#a8a8b3"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="Nom du joueur :" Foreground="White" FontSize="16" Margin="0,0,0,8"/>

                <TextBox x:Name="PlayerNameBox" Height="40" FontSize="18"
                         Style="{StaticResource SearchBoxStyle}"
                         KeyDown="PlayerNameBox_KeyDown"/>

                <TextBlock Text="Joueurs existants :" Foreground="#a8a8b3" FontSize="12" Margin="0,15,0,5"/>

                <ListBox x:Name="ExistingPlayersListBox" Height="80"
                         Background="#1a1a2e" Foreground="White" BorderBrush="#0f3460"
                         FontSize="14" SelectionChanged="ExistingPlayersListBox_SelectionChanged"/>

                <Button x:Name="StartButton" Content="C'est parti !"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="45" FontSize="18" Margin="0,20,0,0"
                        Click="StartButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
